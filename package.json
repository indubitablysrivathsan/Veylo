{
  "name": "blockchain-escrow",
  "version": "0.1.0",
  "description": "Decentralized freelance escrow platform with AI-powered validation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "compile": "npx hardhat compile",
    "deploy:local": "npx hardhat run scripts/deployContracts.ts --network localhost",
    "deploy:sepolia": "npx hardhat run scripts/deployContracts.ts --network sepolia",
    "hardhat:node": "npx hardhat node",
    "validate": "npx ts-node scripts/runValidator.ts",
    "test:contracts": "npx hardhat test",
    "sandbox:build": "docker build -t escrow-sandbox ./sandbox",
    "lint": "npx eslint . --ext .js",
    "lint:fix": "npx eslint . --ext .js --fix"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20.10.0",
    "hardhat": "^2.19.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  }
}