generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id                 Int      @id @default(autoincrement())
  title              String?
  description        String
  clientAddress      String
  freelancerAddress  String?
  requirementsHash   String
  testSuiteHash      String?
  testSuiteJson      Json?
  state              String   @default("CREATED")
  outcome            String   @default("NONE")
  paymentAmountINR    String?
  repoUrl            String?
  submissionHash     String?
  deadline           DateTime?
  createdAt          DateTime @default(now())
  submittedAt        DateTime?
  validatedAt        DateTime?
  closedAt           DateTime?

  createTxHash       String?
  fundTxHash         String?
  validateTxHash     String?

  validationReports  ValidationReport[]
}

model ValidationReport {
  id                 Int @id @default(autoincrement())
  jobId              Int
  job                Job @relation(fields: [jobId], references: [id])

  overallScore       Int
  verdict            String

  executionScore     Int?
  testsPassed        Int?
  testsTotal         Int?

  structureScore     Int?
  lintScore          Int?
  semanticScore      Int?

  semanticReasoning  String?

  reportHash         String
  reportJson         Json?

  createdAt          DateTime @default(now())
}

model Reputation {
  address            String @id
  totalJobs          Int @default(0)
  totalScore         Int @default(0)
  averageScore       Float @default(0)

  successfulJobs     Int @default(0)
  disputedJobs       Int @default(0)
  failedJobs         Int @default(0)

  updatedAt          DateTime @updatedAt
}

model Badge {
  id        Int @id @default(autoincrement())
  address   String
  badgeName String
  tokenId   Int?

  awardedAt DateTime @default(now())

  @@unique([address, badgeName])
}

model SlashRecord {
  address              String @id
  consecutiveFailures  Int @default(0)
  totalSlashes         Int @default(0)
  cooldownUntil        DateTime?
  isBlacklisted        Boolean @default(false)
}