generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String?
  role          String   @default("client")

  passwordHash  String?

  oauthProvider String?
  oauthId       String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Job {
  id                 Int      @id @default(autoincrement())
  title              String?
  description        String
  clientAddress      String
  freelancerAddress  String?
  fundedAt           DateTime?
  techStack          String?
  expectedDeliverable String?

  requirementsHash   String
  testSuiteHash      String?
  testSuiteJson      Json?

  state              String   @default("CREATED")
  outcome            String   @default("NONE")

  paymentAmountINR   String?

  repoUrl            String?
  submissionHash     String?

  commitHash         String?      // ADD
  submissionNotes    String?      // ADD

  deadline           DateTime?

  createdAt          DateTime @default(now())
  submittedAt        DateTime?
  validatedAt        DateTime?
  closedAt           DateTime?

  createTxHash       String?
  fundTxHash         String?
  validateTxHash     String?

  validationReports  ValidationReport[]
}

model ValidationReport {
  id                 Int @id @default(autoincrement())

  jobId              Int @unique
  job                Job @relation(fields: [jobId], references: [id])

  overallScore       Int
  verdict            String

  executionScore     Int?
  testsPassed        Int?
  testsTotal         Int?

  structureScore     Int?
  lintScore          Int?
  semanticScore      Int?

  semanticReasoning  String?

  reportHash         String?
  reportJson         Json?

  createdAt          DateTime @default(now())
}

model Reputation {
  address            String @id
  totalJobs          Int @default(0)
  totalScore         Int @default(0)
  averageScore       Float @default(0)

  successfulJobs     Int @default(0)
  disputedJobs       Int @default(0)
  failedJobs         Int @default(0)

  updatedAt          DateTime @updatedAt
}

model Badge {
  id        Int @id @default(autoincrement())
  address   String
  badgeName String
  tokenId   Int?

  awardedAt DateTime @default(now())

  @@unique([address, badgeName])
}

model SlashRecord {
  address              String @id
  consecutiveFailures  Int @default(0)
  totalSlashes         Int @default(0)
  cooldownUntil        DateTime?
  isBlacklisted        Boolean @default(false)
}